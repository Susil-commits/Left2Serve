# Server
PORT=5000
CLIENT_URL=http://localhost:5173

# Database (PostgreSQL)
# Option A — full connection string (Render Postgres injects this when linked):
# DATABASE_URL=postgresql://user:password@host:5432/left2serve
# Option B — individual fields:
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=left2serve
# Set to 1 if your Postgres host requires SSL (Render external URL, PlanetScale, etc.)
DB_SSL=0

# Auth
JWT_SECRET=replace_with_a_long_random_secret
ADMIN_CODE=change_this_admin_code

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay (online payments — test mode keys start with rzp_test_)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
