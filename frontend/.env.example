# Production: set this to your Render backend URL (e.g. https://left2serve-api.onrender.com)
# In development, leave unset to use the Vite proxy (/api -> localhost:5000)
VITE_API_URL=

# Razorpay public key (test mode starts with rzp_test_). Server-side secret stays on the backend.
VITE_RAZORPAY_KEY_ID=
